    //         "performance": "пғ§",
    //         "balanced": "пүҺ",
    //         "power-saver": "пҒ¬"
    //     }
    // },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}{volume}%",
        "format-muted": "вң–  Muted",
        "format-bluetooth": "{icon}пҠ”  {volume}%",
        "format-bluetooth-muted": "вң–  {icon}пҠ”",
        "format-icons": {
            "headphone": "пҖҘ",
            "headset": "пҖҘ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": [
                "пҖҰ",
                "пҖ§",
                "пҖЁ "
            ]
        },
        "on-click": "amixer set Master 5%-",
        "on-click-middle": "pavucontrol",
        "on-click-right": "amixer set Master 5%+"
    },

