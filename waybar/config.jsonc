    "temperature": {
        "critical-threshold": 80,
        "format-critical": "пӢҮ {temperatureC}В°C",
        "format": "пӢү {temperatureC}В°C",
        "tooltip-format": "е’•, дёҚ...дёҚиҰҒзғ§иө·жқҘе‘Җ(((;к’ӘкҲҠк’Ә;)))"
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "reverse-direction": true
    }
}
