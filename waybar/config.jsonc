    //     "tooltip-format": "еҝ«з”Ёд»»еҠЎжқҘеЎ«ж»ЎжҲ‘еҗ§вҷЎ",
    //     "on-click-middle": "exec htop"
    // },

    "network": {
        "interval": 1,
        "tooltip": true,
        "format-wifi": "{icon}",
        "tooltip-format-wifi": "вҶ‘вҶ“ {bandwidthUpBytes}|{bandwidthDownBytes}\n{icon} {essid} @ {signalStrength}%",
        "format-ethernet": "о¬Ғ {bandwidthDownBytes}",
        "tooltip-format-ethernet": "вҶ‘вҶ“ {bandwidthUpBytes}|{bandwidthDownBytes}",
        "format-disconnected": "в“ҳ Lost",
        "format-icons": [
            "у°ӨҜ",
            "у°Өҹ",
            "у°Өў",
            "у°Өў",
            "у°ӨЁ"
        ],
        "tooltip-format-disconnected": "жІЎжңүиҝһжҺҘе‘ў, зңҹжҳҜжқӮйұје‘ўвҷЎ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-middle": ""
    },

    // "power-profiles-daemon": {
    //     "format": "{icon}",
    //     "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    //     "tooltip": true,
    //     "format-icons": {
